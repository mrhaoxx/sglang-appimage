# Edit these pins.
PYTHON_SHORT=3.12

# SGLang source repo and branch/tag/commit
SGLANG_REPO=https://github.com/kvcache-ai/sglang.git
SGLANG_REF=main

# KTransformers source repo and branch/tag/commit
KTRANSFORMERS_REPO=https://github.com/kvcache-ai/ktransformers.git
KTRANSFORMERS_REF=main

# PyPI mirror (TUNA)
PYPI_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple

# Proxy (local build)
PROXY=http://192.168.200.14:17890
NO_PROXY=".cn"

# CUDA toolkit installation from NVIDIA .run package
# If CUDA_RUNFILE_URL is empty, build script will auto-discover a matching runfile from index URL + regex.
CUDA_RUNFILE_URL=https://developer.download.nvidia.com/compute/cuda/12.9.1/local_installers/cuda_12.9.1_575.57.08_linux.run
CUDA_RUNFILE_INDEX_URL=https://developer.download.nvidia.com/compute/cuda/12.9.1/local_installers/
CUDA_RUNFILE_NAME_REGEX=^cuda_12\.9\.[0-9]+_[0-9.]+_linux\.run$
